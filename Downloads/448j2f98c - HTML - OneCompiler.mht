.loginBtn { box-sizing: border-box; position: relative; margin: 0.2em; padding: 0px 15px 0px 46px; border: none; text-align: left; line-height: 34px; white-space: nowrap; border-radius: 0.2em; font-size: 16px; color: rgb(255, 255, 255); cursor: pointer; }

.loginBtn::before { content: ""; box-sizing: border-box; position: absolute; top: 0px; left: 0px; width: 34px; height: 100%; }

.loginBtn:focus { outline: none; }

.loginBtn:active { box-shadow: rgba(0, 0, 0, 0.1) 0px 0px 0px 32px inset; }

.loginBtn--facebook { background-color: rgb(76, 105, 186); background-image: linear-gradient(rgb(76, 105, 186), rgb(59, 85, 160)); text-shadow: rgb(53, 76, 140) 0px -1px 0px; }

.loginBtn--facebook::before { border-right: 1px solid rgb(54, 78, 146); background: url("https://s3-us-west-2.amazonaws.com/s.cdpn.io/14082/icon_facebook.png") 6px 6px no-repeat; }

.loginBtn--facebook:focus, .loginBtn--facebook:hover { background-color: rgb(91, 123, 213); background-image: linear-gradient(rgb(91, 123, 213), rgb(72, 100, 177)); }

.loginBtn--google { background: rgb(221, 75, 57); }

.loginBtn--google::before { border-right: 1px solid rgb(187, 63, 48); background: url("/static/images/icon_google.png") 6px 6px no-repeat; }

.loginBtn--google:focus, .loginBtn--google:hover { background: rgb(176, 60, 45); }

.loginBtn--github { background: rgb(79, 83, 87); }

.loginBtn--github::before { border-right: 1px solid rgb(36, 41, 46); background: url("https://www.gstatic.com/mobilesdk/160409_mobilesdk/images/auth_service_github.svg") 6px 6px no-repeat; }

.loginBtn--github:focus, .loginBtn--github:hover { background: rgb(57, 62, 66); }

.grayBorderBottom { border-bottom: 1px solid rgb(229, 229, 229); }

#nprogress { pointer-events: none; }

#nprogress .bar { background: rgb(233, 30, 99); position: fixed; z-index: 1031; top: 0px; left: 0px; width: 100%; height: 2px; }

#nprogress .peg { display: block; position: absolute; right: 0px; width: 100px; height: 100%; box-shadow: rgb(235, 52, 114) 0px 0px 10px, rgb(235, 52, 114) 0px 0px 5px; opacity: 1; transform: rotate(3deg) translateY(-4px); }

#nprogress .spinner { display: block; position: fixed; z-index: 1031; top: 15px; right: 15px; }

#nprogress .spinner-icon { width: 18px; height: 18px; box-sizing: border-box; border-color: rgb(92, 106, 196) rgba(0, 0, 0, 0) rgba(0, 0, 0, 0) rgb(92, 106, 196); border-style: solid; border-width: 2px; border-radius: 50%; animation: 0.4s linear 0s infinite normal none running nprogress-spinner; }

.nprogress-custom-parent { overflow: hidden; position: relative; }

.nprogress-custom-parent #nprogress .bar, .nprogress-custom-parent #nprogress .spinner { position: absolute; }

