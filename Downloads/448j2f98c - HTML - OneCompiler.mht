@charset "utf-8";

html { -webkit-font-smoothing: antialiased; overflow-y: scroll; }

.text-highlighted { color: rgb(249, 185, 52); }

.text-highlighted__primary { color: rgb(63, 81, 181); }

a { text-decoration: none; color: rgb(80, 99, 240); }

.ace-github .ace_gutter, .ace-xcode .ace_gutter { background: rgb(243, 243, 243); }

.ace-dracula { background-color: rgb(18, 18, 18); }

.ace-dracula .ace_gutter { background: rgb(36, 36, 43); }

.textUnderline { text-decoration: underline; }

.textDecorationNone { text-decoration: none; }

.textTransformNone { text-transform: none; }

.footerLink, .footerText { color: rgb(173, 181, 189) !important; }

.footerLink:hover { color: rgb(255, 255, 255) !important; }

.smartLink { text-decoration: none; }

.smartLink:hover { cursor: pointer; text-decoration: underline; }

.codeCardCode { text-decoration: none; color: rgb(0, 0, 0); }

.paper-content { word-break: break-word; padding: 50px; }

@media screen and (max-width: 420px) {
  .paper-content { padding: 30px 10px; }
}

.space-between-flex { display: flex; justify-content: space-between; }

.center-items-flex { display: flex; align-items: center; }

.m5 { margin: 5px; }

.m10 { margin: 10px; }

.m15 { margin: 15px; }

.mb5 { margin-bottom: 5px; }

.mb10 { margin-bottom: 10px; }

.mb20 { margin-bottom: 20px; }

.mr10 { margin-right: 10px !important; }

.mr15 { margin-right: 15px !important; }

.mr20 { margin-right: 20px !important; }

.ml5 { margin-left: 5px; }

.ml10, .mlr10 { margin-left: 10px !important; }

.mlr10 { margin-right: 10px !important; }

.mlr20 { margin-right: 20px !important; margin-left: 20px !important; }

.mt10 { margin-top: 10px !important; }

.mt20 { margin-top: 20px !important; }

.mt30 { margin-top: 30px !important; }

.pr10 { padding-right: 10px; }

.pr20 { padding-right: 20px; }

.pr30 { padding-right: 30px; }

.post-padding { padding-right: 40px; }

@media screen and (max-width: 420px) {
  .post-padding { padding: 0px; }
}

.maxLinesCheatSheetDescription { -webkit-line-clamp: 2; line-height: 1.4em; height: 2.8em; min-height: 2.8em; }

.maxLinesCheatSheetDescription, .maxLinesProblemTitleDescription { overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-box-orient: vertical; }

.maxLinesProblemTitleDescription { -webkit-line-clamp: 1; height: 1.4em; min-height: 1.4em; }

.oc-card { border: 1px solid rgb(218, 220, 224); margin-bottom: 20px; }

.oc-tabs { border-bottom: 1px solid rgb(218, 220, 224); }

.unselectable { user-select: none; }

:root { --separator-border: none !important; --focus-border: #d4d8d8 !important; }

code { word-break: break-word; }

li code, p code { font-size: 0.85rem; }

pre code { font-size: 0.88rem; }

.md-view { word-break: break-word; }

.md-view li, .md-view p { font-size: 1rem; }

.md-view blockquote { color: rgb(102, 102, 102); margin: 0px; padding-left: 3em; border-left: 0.5em solid rgb(238, 238, 238); background: none 0px 0px repeat scroll rgba(102, 128, 153, 0.05); }

.md-view hr { margin-top: 1rem; margin-bottom: 1rem; border-width: 1px 0px 0px; border-right-style: initial; border-bottom-style: initial; border-left-style: initial; border-right-color: initial; border-bottom-color: initial; border-left-color: initial; border-image: initial; border-top-style: solid; border-top-color: rgba(0, 0, 0, 0.1); box-sizing: content-box; height: 0px; overflow: visible; }

.md-view img { max-width: 95%; }

.md-view table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; }

.md-view table th { font-weight: 600; white-space: nowrap; }

.md-view table td, .md-view table th { padding: 2px 6px; border: 1px solid rgb(223, 226, 229); }

.md-view table tr { background-color: rgb(255, 255, 255); border-top: 1px solid rgb(198, 203, 209); }

.md-view table tr:nth-child(2n) { background-color: rgb(246, 248, 250); }

.oc-theme-light code { border-radius: 5px; overflow-x: auto; padding: 0.1em 0.5em; color: rgb(51, 51, 51); background: rgb(236, 240, 241); }

.oc-theme-light li code, .oc-theme-light p code { color: rgb(233, 30, 99); }

.oc-theme-light pre code { display: block; }

.oc-theme-light .hljs { overflow-x: auto; padding: 0.5em; color: rgb(51, 51, 51); background: rgb(248, 248, 248); }

.oc-theme-light .hljs-comment, .oc-theme-light .hljs-quote { color: rgb(153, 153, 136); font-style: italic; }

.oc-theme-light .hljs-keyword, .oc-theme-light .hljs-selector-tag, .oc-theme-light .hljs-subst { color: rgb(51, 51, 51); font-weight: 700; }

.oc-theme-light .hljs-literal, .oc-theme-light .hljs-number, .oc-theme-light .hljs-tag .hljs-attr, .oc-theme-light .hljs-template-variable, .oc-theme-light .hljs-variable { color: teal; }

.oc-theme-light .hljs-doctag, .oc-theme-light .hljs-string { color: rgb(221, 17, 68); }

.oc-theme-light .hljs-section, .oc-theme-light .hljs-selector-id, .oc-theme-light .hljs-title { color: rgb(153, 0, 0); font-weight: 700; }

.oc-theme-light .hljs-subst { font-weight: 400; }

.oc-theme-light .hljs-class .hljs-title, .oc-theme-light .hljs-type { color: rgb(68, 85, 136); font-weight: 700; }

.oc-theme-light .hljs-attribute, .oc-theme-light .hljs-name, .oc-theme-light .hljs-tag { color: navy; font-weight: 400; }

.oc-theme-light .hljs-link, .oc-theme-light .hljs-regexp { color: rgb(0, 153, 38); }

.oc-theme-light .hljs-bullet, .oc-theme-light .hljs-symbol { color: rgb(153, 0, 115); }

.oc-theme-light .hljs-built_in, .oc-theme-light .hljs-builtin-name { color: rgb(0, 134, 179); }

.oc-theme-light .hljs-meta { color: rgb(153, 153, 153); font-weight: 700; }

.oc-theme-light .hljs-deletion { background: rgb(255, 221, 221); }

.oc-theme-light .hljs-addition { background: rgb(221, 255, 221); }

.oc-theme-light .hljs-emphasis { font-style: italic; }

.oc-theme-light .hljs-strong { font-weight: 700; }

.oc-theme-dark code { border-radius: 5px; overflow-x: auto; padding: 0.2em 0.5em; background: rgb(40, 42, 54); color: rgb(248, 248, 242); }

.oc-theme-dark li code, .oc-theme-dark p code { color: rgb(248, 248, 242); }

.oc-theme-dark pre code { display: block; }

.oc-theme-dark .hljs { overflow-x: auto; padding: 0.5em; background: rgb(40, 42, 54); }

.oc-theme-dark .hljs-keyword, .oc-theme-dark .hljs-link, .oc-theme-dark .hljs-literal, .oc-theme-dark .hljs-section, .oc-theme-dark .hljs-selector-tag { color: rgb(139, 233, 253); }

.oc-theme-dark .hljs-function .hljs-keyword { color: rgb(255, 121, 198); }

.oc-theme-dark .hljs, .oc-theme-dark .hljs-subst { color: rgb(248, 248, 242); }

